---
import { withBase } from '../../lib/paths';

interface NavPost {
    slug: string;
    title: string;
}

interface Props {
    prevPost: NavPost | null;
    nextPost: NavPost | null;
}

const { prevPost, nextPost } = Astro.props;
---

<nav aria-label="Article navigation" class="article-nav">
    {
        prevPost ? (
            <a href={withBase(`/posts/${prevPost.slug}`)} class="article-nav__link article-nav__link--prev">
                <span class="article-nav__label">&lt;&lt; Previous</span>
                <span class="article-nav__title">{prevPost.title}</span>
            </a>
        ) : (
            <div class="article-nav__spacer" aria-hidden="true"></div>
        )
    }

    <a href={withBase('/posts')} class="article-nav__link article-nav__link--center">
        <span class="article-nav__label">All Articles</span>
        <span class="article-nav__subtitle">Browse library</span>
    </a>

    {
        nextPost ? (
            <a href={withBase(`/posts/${nextPost.slug}`)} class="article-nav__link article-nav__link--next">
                <span class="article-nav__label">Next &gt;&gt;</span>
                <span class="article-nav__title">{nextPost.title}</span>
            </a>
        ) : (
            <div class="article-nav__spacer" aria-hidden="true"></div>
        )
    }
</nav>
