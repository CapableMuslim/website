---
import PlatformIcon from '../community/PlatformIcon.astro';
import { socialConnectPlatforms, redditConnectPlatform } from '../../data/community';
---

<aside class="article-follow" aria-label="Follow The Capable Muslim">
    <h2 class="article-follow__title">Follow The Capable Muslim</h2>
    <ul class="article-follow__grid">
        {
            socialConnectPlatforms.map((platform) => (
                <li>
                    <a
                        href={platform.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="article-follow__link"
                        aria-label={platform.name}
                    >
                        <PlatformIcon id={platform.id} class="h-4 w-4" />
                    </a>
                </li>
            ))
        }
    </ul>
    <div class="mt-1.5 flex justify-center">
        <a
            href={redditConnectPlatform.href}
            target="_blank"
            rel="noopener noreferrer"
            class="article-follow__link h-9 w-9"
            aria-label={redditConnectPlatform.name}
        >
            <PlatformIcon id={redditConnectPlatform.id} class="h-4 w-4" />
        </a>
    </div>
</aside>
