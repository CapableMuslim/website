---
import SectionHeader from '../ui/SectionHeader.astro';
import ArticleCard from '../ui/ArticleCard.astro';
import { formatDate } from '../../lib/posts';
import type { PostCard } from '../../lib/posts';

interface Props {
    posts: PostCard[];
}

const { posts } = Astro.props;
const [lead, ...rest] = posts;
---

{
    posts.length > 0 && (
        <section class="section-padding bg-cream">
            <div class="container-content">
                <SectionHeader
                    label="Latest"
                    title="Recent writing"
                    description="Fresh perspectives on building a capable life."
                    class="mb-12"
                />

                <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
                    {lead && (
                        <div class="lg:col-span-7">
                            <a href={`/posts/${lead.slug}`} class="group block">
                                <article>
                                    <div class="mb-4 flex flex-wrap items-center gap-3">
                                        <span class="category-tag">{lead.pillar}</span>
                                        <span class="reading-time">{lead.readingTime} min read</span>
                                        {lead.pubDate && <span class="reading-time">{formatDate(lead.pubDate)}</span>}
                                    </div>
                                    <h3 class="font-display text-display-sm font-bold leading-tight text-ink-900 transition-colors group-hover:text-forest">
                                        {lead.title}
                                    </h3>
                                    {lead.description && (
                                        <p class="mt-4 max-w-prose text-lg leading-relaxed text-ink-500">
                                            {lead.description}
                                        </p>
                                    )}
                                    <span class="mt-6 inline-flex items-center text-sm font-semibold text-forest">
                                        Continue reading
                                        <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </span>
                                </article>
                            </a>
                        </div>
                    )}

                    <div class="lg:col-span-5">
                        <div class="lg:border-l lg:border-ink-100 lg:pl-10">
                            {rest.map((post) => (
                                <ArticleCard post={post} variant="compact" showDescription={false} />
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )
}
