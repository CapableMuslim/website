---
import SectionHeader from '../ui/SectionHeader.astro';
import BeehiivForm from '../BeehiivForm.astro';
import { withBase } from '../../lib/paths';
---

<section id="newsletter" class="section-padding-sm section-surface-alt border-t border-gold/10">
    <div class="container-content">
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
            <div>
                <SectionHeader
                    label="Newsletter"
                    title="One thoughtful letter, weekly"
                    description="Practical ideas on health, discipline, faith, and capability. No hype, no filler — just writing worth reading."
                />
                <a
                    href={withBase('/newsletter')}
                    class="mt-6 inline-flex items-center text-sm font-semibold text-gold transition-colors hover:text-gold-300"
                >
                    Learn more about the newsletter
                    <svg class="ml-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>

            <div class="card p-6 sm:p-8 text-center">
                <h2 class="text-balance font-display text-xl text-gold sm:text-2xl">Capable Muslim's Newsletter</h2>
                <p class="mt-2 text-balance text-center text-sm leading-relaxed text-parchment-300 sm:text-pretty md:whitespace-nowrap">
                    Helping Muslims become healthier, stronger, wiser, and more capable.
                </p>
                <div class="mt-5">
                    <BeehiivForm variant="wide" />
                </div>
                <p class="mt-4 text-xs leading-relaxed text-parchment-400">
                    Free. Unsubscribe anytime. We respect your attention.
                </p>
            </div>
        </div>
    </div>
</section>
