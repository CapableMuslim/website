---
import type { PostCard } from '../../lib/posts';

interface Props {
    post: PostCard;
    variant?: 'default' | 'featured' | 'compact';
    showDescription?: boolean;
    showImage?: boolean;
}

const { post, variant = 'default', showDescription = true, showImage = true } = Astro.props;
const href = `/posts/${post.slug}`;
const tag = post.subpillar || post.pillar;
---

<a href={href} class="group block h-full">
    {
        variant === 'featured' ? (
            <article class="card h-full p-6 sm:p-8">
                <div class="mb-4 flex items-center gap-3">
                    <span class="category-tag">{post.pillar}</span>
                    <span class="reading-time">{post.readingTime} min read</span>
                </div>
                <h3 class="font-display text-xl font-bold leading-snug text-parchment transition-colors group-hover:text-gold sm:text-2xl">
                    {post.title}
                </h3>
                {showDescription && post.description && (
                    <p class="mt-3 leading-relaxed text-parchment-300 line-clamp-3 text-justify">
                        {post.description}
                    </p>
                )}
                <span class="mt-5 inline-flex items-center text-sm font-semibold text-gold opacity-0 transition-opacity group-hover:opacity-100">
                    Read article
                    <svg class="ml-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </span>
            </article>
        ) : variant === 'compact' ? (
            <article class="border-b border-gold/10 py-5 last:border-0">
                <div class="mb-2 flex items-center gap-3">
                    <span class="category-tag">{tag}</span>
                    <span class="reading-time">{post.readingTime} min</span>
                </div>
                <h3 class="font-display text-lg font-bold leading-snug text-parchment transition-colors group-hover:text-gold">
                    {post.title}
                </h3>
            </article>
        ) : (
            <article class="card h-full overflow-hidden p-0">
                {showImage && (
                    <div class="relative aspect-[16/10] overflow-hidden">
                        <img
                            src={post.image}
                            alt=""
                            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-bronze-900/95 via-bronze-900/30 to-transparent" />
                        {tag && (
                            <span class="category-tag absolute bottom-3 left-4 rounded bg-bronze-950/70 px-2 py-1 backdrop-blur-sm">
                                {tag}
                            </span>
                        )}
                    </div>
                )}
                <div class="p-5 sm:p-6">
                    {!showImage && (
                        <div class="mb-3 flex items-center gap-3">
                            <span class="category-tag">{tag}</span>
                            <span class="reading-time">{post.readingTime} min read</span>
                        </div>
                    )}
                    {showImage && (
                        <span class="reading-time mb-2 block">{post.readingTime} min read</span>
                    )}
                    <h3 class="font-display text-lg font-bold leading-snug text-parchment transition-colors group-hover:text-gold sm:text-xl">
                        {post.title}
                    </h3>
                    {showDescription && post.description && (
                        <p class="mt-2 text-sm leading-relaxed text-parchment-300 line-clamp-2 text-justify">
                            {post.description}
                        </p>
                    )}
                </div>
            </article>
        )
    }
</a>
