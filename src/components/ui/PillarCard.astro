const path = icons[pillar.icon] ?? icons.compass;
---

<a href={pillar.href} class="group block h-full">
    <article class="card h-full p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded bg-gold/10 text-gold transition-colors group-hover:bg-gold group-hover:text-bronze-950">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={path} />
            </svg>
        </div>
        <h3 class="font-display text-lg text-parchment transition-colors group-hover:text-gold">
            {pillar.name}
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-parchment-300">
            {pillar.description}
        </p>
    </article>
</a>
