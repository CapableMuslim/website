---
import "../styles/global.css";
import Search from "../components/Search";
import Navigation from "../components/Navigation";
import { siteConfig } from "../data/site";
import { navLinks, articleCategories, footerCategories, footerCompanyLinks, supportMissionLink } from "../data/landing";
import { socialConnectPlatforms, redditConnectPlatform } from "../data/community";
import PlatformIcon from "../components/community/PlatformIcon.astro";
import FooterNewsletter from "../components/FooterNewsletter.astro";
import { withBase } from "../lib/paths";

interface Props {
	title: string;
	description?: string;
	/** Overrides the default "{title} | {siteName}" document title and og:title */
	fullTitle?: string;
}

const { title, description = siteConfig.defaultDescription, fullTitle } = Astro.props;
const { name: siteName, logo } = siteConfig;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(withBase(logo.full), Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicons/favicon-32x32.png')} />
		<link rel="icon" type="image/png" sizes="16x16" href={withBase('/favicons/favicon-16x16.png')} />
		<link rel="apple-touch-icon" sizes="180x180" href={withBase('/favicons/apple-touch-icon.png')} />
		<link rel="icon" href={withBase('/favicons/favicon.ico')} />
		<link rel="icon" type="image/png" href={withBase(logo.icon)} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteName} RSS Feed`}
			href={new URL(withBase('/rss.xml'), Astro.site)}
		/>
		<meta property="og:title" content={fullTitle ?? `${title} | ${siteName}`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&family=Source+Sans+3:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<title>{fullTitle ?? `${title} | ${siteName}`}</title>
	</head>
	<body class="bg-bronze-950 text-parchment-200">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:bg-gold focus:px-4 focus:py-2 focus:text-bronze-950"
		>
			Skip to content
		</a>

		<header
			id="site-header"
			class="fixed left-0 right-0 top-0 z-50 border-b border-gold/15 bg-bronze-950/95 backdrop-blur-md transition-shadow duration-200"
		>
			<div class="container-content relative flex h-16 items-center justify-between gap-4 lg:h-[4.5rem]">
				<a href={withBase('/')} class="relative z-10 flex shrink-0 items-center gap-3" aria-label={`${siteName} home`}>
					<img
						src={withBase(logo.nav)}
						alt=""
						class="h-9 w-auto object-contain lg:h-10"
						width="120"
						height="40"
					/>
				</a>

				<div class="pointer-events-none absolute inset-x-0 hidden justify-center lg:flex">
					<div class="pointer-events-auto">
						<Navigation client:load />
					</div>
				</div>

				<div class="relative z-10 flex items-center gap-3 sm:gap-4">
					<a
						href={supportMissionLink.href}
						class="nav-link hidden whitespace-nowrap sm:inline-flex"
					>
						{supportMissionLink.label}
					</a>
					<div class="hidden sm:block">
						<Search client:load variant="icon" />
					</div>

					<button
						id="mobile-menu-btn"
						type="button"
						class="flex h-10 w-10 items-center justify-center rounded text-parchment-300 transition-colors hover:bg-gold/10 hover:text-parchment lg:hidden"
						aria-label="Open menu"
						aria-expanded="false"
						aria-controls="mobile-menu"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="3" y1="12" x2="21" y2="12"></line>
							<line x1="3" y1="6" x2="21" y2="6"></line>
							<line x1="3" y1="18" x2="21" y2="18"></line>
						</svg>
					</button>
				</div>
			</div>
		</header>

		<div
			id="mobile-menu"
			class="fixed inset-0 z-40 flex translate-x-full flex-col bg-bronze-950 pt-20 transition-transform duration-300 lg:hidden"
			aria-hidden="true"
		>
			<div class="border-b border-gold/10 px-5 pb-5">
				<Search client:load variant="mobile" />
			</div>
			<div class="border-b border-gold/10 px-5 py-4">
				<a href={supportMissionLink.href} class="nav-link text-base">
					{supportMissionLink.label}
				</a>
			</div>
			<nav class="flex-1 overflow-y-auto px-5 py-6" aria-label="Mobile navigation">
				<ul class="space-y-1">
					{
						navLinks.map((link) =>
							link.dropdown === 'articles' ? (
								<li>
									<details class="group">
										<summary class="flex cursor-pointer list-none items-center justify-between rounded px-3 py-3 text-lg font-bold text-white transition-colors hover:bg-gold/10 hover:text-gold [&::-webkit-details-marker]:hidden">
											{link.label}
											<svg class="h-4 w-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
											</svg>
										</summary>
										<ul class="mb-2 ml-3 space-y-1 border-l border-gold/10 pl-4">
											<li>
												<a href={withBase('/posts')} class="block rounded px-2 py-2 text-sm font-semibold text-gold">
													All Articles
												</a>
											</li>
											{articleCategories.map((category) => (
												<li>
													<details class="group/cat">
														<summary class="flex cursor-pointer list-none items-center justify-between rounded px-2 py-2 text-sm text-parchment-300 transition-colors hover:text-parchment [&::-webkit-details-marker]:hidden">
															{category.name}
															<svg class="h-3 w-3 transition-transform group-open/cat:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
																<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
															</svg>
														</summary>
														<ul class="ml-3 space-y-0.5 border-l border-gold/10 py-1 pl-3">
															{category.subpillars.map((sub) => (
																<li>
																	<a href={sub.href} class="block rounded px-2 py-1.5 text-xs text-parchment-400 transition-colors hover:text-gold">
																		{sub.label}
																	</a>
																</li>
															))}
														</ul>
													</details>
												</li>
											))}
										</ul>
									</details>
								</li>
							) : (
								<li>
									<a
										href={link.href}
										class="block rounded px-3 py-3 text-lg font-bold text-white transition-colors hover:bg-gold/10 hover:text-gold"
									>
										{link.label}
									</a>
								</li>
							),
						)
					}
				</ul>
			</nav>
		</div>

		<main id="main-content" class="pt-16 lg:pt-[4.5rem]">
			<slot />
		</main>

		<footer class="border-t border-gold/10 bg-bronze-950 text-parchment-300">
			<div class="container-content section-padding pb-10">
				<div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-12 lg:gap-8">
					<div class="lg:col-span-5">
						<p class="font-display text-xl text-parchment">{siteName}</p>
						<p class="mt-4 max-w-sm text-justify text-sm leading-relaxed text-parchment-400">
							{siteConfig.footerTagline}
						</p>
						<FooterNewsletter />
					</div>

					<div class="text-center lg:col-span-3">
						<h4 class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-gold">
							Categories
						</h4>
						<ul class="grid grid-cols-2 gap-x-4 gap-y-2.5">
							{
								footerCategories.map((cat) => (
									<li>
										<a href={cat.href} class="text-sm text-parchment-400 transition-colors hover:text-parchment">
											{cat.label}
										</a>
									</li>
								))
							}
						</ul>
					</div>

					<div class="text-center lg:col-span-2">
						<h4 class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-gold">
							Company
						</h4>
						<ul class="space-y-2.5">
							{
								footerCompanyLinks.map((link) => (
									<li>
										<a href={link.href} class="text-sm text-parchment-400 transition-colors hover:text-parchment">
											{link.label}
										</a>
									</li>
								))
							}
						</ul>
					</div>

					<div class="text-center lg:col-span-2">
						<h4 class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-gold">
							Connect
						</h4>
						<div class="mx-auto w-fit">
							<div class="grid grid-cols-3 justify-items-center gap-3">
								{
									socialConnectPlatforms.map((platform) => (
										<a
											href={platform.href}
											target="_blank"
											rel="noopener noreferrer"
											class="inline-flex text-parchment-400 transition-colors hover:text-gold"
											aria-label={platform.name}
										>
											<PlatformIcon id={platform.id} class="h-5 w-5" />
										</a>
									))
								}
							</div>
							<div class="mt-3 flex justify-center">
								<a
									href={redditConnectPlatform.href}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex text-parchment-400 transition-colors hover:text-gold"
									aria-label={redditConnectPlatform.name}
								>
									<PlatformIcon id={redditConnectPlatform.id} class="h-5 w-5" />
								</a>
							</div>
						</div>

						<p class="mt-6 text-sm">
							<a href={`mailto:${siteConfig.email}`} class="text-parchment-400 transition-colors hover:text-gold">
								{siteConfig.email}
							</a>
						</p>
					</div>
				</div>

				<div class="mt-12 h-px w-full bg-gold/10"></div>

				<div class="mt-8 flex flex-col items-center justify-between gap-4 sm:flex-row">
					<p class="text-xs text-parchment">
						&copy; {new Date().getFullYear()} {siteName}. All rights reserved.
					</p>
					<a href={withBase('/privacy-policy')} class="text-xs text-parchment transition-colors hover:text-gold">
						Privacy Policy
					</a>
				</div>
			</div>
		</footer>

		<script>
			const btn = document.getElementById('mobile-menu-btn');
			const menu = document.getElementById('mobile-menu');
			const header = document.getElementById('site-header');
			let isMenuOpen = false;

			const menuIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>`;
			const closeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;

			if (btn && menu) {
				btn.addEventListener('click', () => {
					isMenuOpen = !isMenuOpen;
					if (isMenuOpen) {
						menu.classList.remove('translate-x-full');
						menu.setAttribute('aria-hidden', 'false');
						btn.setAttribute('aria-expanded', 'true');
						btn.setAttribute('aria-label', 'Close menu');
						btn.innerHTML = closeIcon;
						document.body.style.overflow = 'hidden';
					} else {
						menu.classList.add('translate-x-full');
						menu.setAttribute('aria-hidden', 'true');
						btn.setAttribute('aria-expanded', 'false');
						btn.setAttribute('aria-label', 'Open menu');
						btn.innerHTML = menuIcon;
						document.body.style.overflow = '';
					}
				});
			}

			window.addEventListener(
				'scroll',
				() => {
					if (header) header.classList.toggle('shadow-subtle', window.scrollY > 10);
				},
				{ passive: true },
			);
		</script>
	</body>
</html>
