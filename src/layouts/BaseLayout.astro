---
import "../styles/global.css";
import Search from "../components/Search";
import Navigation from "../components/Navigation";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The Inner Fire - Unleash your potential" } =
	Astro.props;

const footerPillars = [
	{ name: "HEALTH" },
	{ name: "MINDSET" },
	{ name: "SOCIAL" },
	{ name: "FITNESS" },
	{ name: "SKILLS" },
	{ name: "STYLE" },
	{ name: "CULTURE" },
	{ name: "FINANCE" },
	{ name: "BOOKSHELF" },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<title>{title} | The Inner Fire</title>
	</head>
	<body
		class="selection:bg-primary-100 selection:text-primary-900 bg-[#050505]"
	>
		<header
			class="fixed top-0 left-0 right-0 z-50 bg-[#050505]/80 backdrop-blur-md border-b border-white/5"
		>
			<div class="flex items-center h-20 px-6">
				<a href="/" class="block group flex-shrink-0">
					<img
						src="/logo.png"
						alt="The Inner Fire"
						class="h-16 w-auto object-contain brightness-100 contrast-125"
					/>
				</a>

				<div class="flex-1 min-w-[3rem]"></div>

				<div class="flex-shrink-0">
					<Navigation client:load />
				</div>

				<div class="flex-1 min-w-[3rem]"></div>

				<div class="flex items-center space-x-4 flex-shrink-0">
					<div class="hidden md:block">
						<Search client:load />
					</div>

					<button
						id="mobile-menu-btn"
						class="xl:hidden p-2 text-gray-400 hover:text-white transition-colors"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><line x1="3" y1="12" x2="21" y2="12"></line><line
								x1="3"
								y1="6"
								x2="21"
								y2="6"></line><line
								x1="3"
								y1="18"
								x2="21"
								y2="18"></line></svg
						>
					</button>
				</div>
			</div>
		</header>

		<div
			id="mobile-menu"
			class="fixed inset-0 z-40 bg-[#050505] transform translate-x-full transition-transform duration-300 pt-24 pb-10 px-6 overflow-y-auto xl:hidden flex flex-col"
		>
			<nav class="flex flex-col space-y-6 mb-10">
				{
					footerPillars.map((pillar) => (
						<a
							href={`/pillars/${pillar.name.toLowerCase()}`}
							class="text-2xl font-black text-white hover:text-primary-500 uppercase tracking-tighter border-b border-white/5 pb-4"
						>
							{pillar.name}
						</a>
					))
				}
			</nav>
			<div class="mt-auto space-y-4">
				<a
					href="/about"
					class="block text-gray-400 font-bold uppercase tracking-widest text-sm"
					>About</a
				>
				<a
					href="/contact"
					class="block text-gray-400 font-bold uppercase tracking-widest text-sm"
					>Contact</a
				>
				<a
					href="/faq"
					class="block text-gray-400 font-bold uppercase tracking-widest text-sm"
					>FAQ</a
				>
			</div>
		</div>

		<main class="pt-20">
			<slot />
		</main>

		<footer
			class="bg-[#050505] border-t border-gray-800 pt-20 pb-10 mt-20 text-gray-400"
		>
			<div class="container mx-auto px-6">
				<div
					class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-12 mb-16"
				>
					<div class="flex flex-col flex-shrink-0">
						<h4
							class="font-extrabold text-sm uppercase tracking-wider text-white mb-4"
						>
							The Inner Fire
						</h4>
						<p
							class="text-sm leading-relaxed text-gray-500 font-medium text-justify"
						>
							The Inner Fire was born from the realization that
							modern society is designed to keep us comfortable,
							weak, and distracted. We provide the antidote
							through radical discipline.
						</p>
					</div>

					<div
						class="flex flex-col items-center xl:items-start text-center xl:text-left"
					>
						<h4
							class="font-extrabold text-sm uppercase tracking-wider text-white mb-6"
						>
							Pillars
						</h4>
						<div
							class="grid grid-cols-3 xl:grid-cols-2 gap-x-6 gap-y-3"
						>
							<a
								href="/pillars/health"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Health</a
							>
							<a
								href="/pillars/mindset"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Mindset</a
							>
							<a
								href="/pillars/social"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Social</a
							>

							<a
								href="/pillars/fitness"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Fitness</a
							>
							<a
								href="/pillars/skills"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Skills</a
							>
							<a
								href="/pillars/style"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Style</a
							>

							<a
								href="/pillars/culture"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Culture</a
							>
							<a
								href="/pillars/finance"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Finance</a
							>
							<a
								href="/bookshelf"
								class="text-xs font-bold text-gray-500 hover:text-primary-500 uppercase tracking-wide transition-colors"
								>Bookshelf</a
							>
						</div>
					</div>

					<div
						class="flex flex-col items-center xl:items-start text-center xl:text-left"
					>
						<h4
							class="font-extrabold mb-6 text-sm uppercase tracking-wider text-white"
						>
							Company
						</h4>
						<ul class="space-y-4">
							<li>
								<a
									href="/about"
									class="text-xs hover:text-primary-500 uppercase tracking-widest font-bold text-gray-500 transition-colors"
									>About</a
								>
							</li>
							<li>
								<a
									href="/contact"
									class="text-xs hover:text-primary-500 uppercase tracking-widest font-bold text-gray-500 transition-colors"
									>Contact</a
								>
							</li>
							<li>
								<a
									href="/faq"
									class="text-xs hover:text-primary-500 uppercase tracking-widest font-bold text-gray-500 transition-colors"
									>FAQ</a
								>
							</li>
							<li>
								<a
									href="/privacy-policy"
									class="text-xs hover:text-primary-500 uppercase tracking-widest font-bold text-gray-500 transition-colors"
									>Privacy Policy</a
								>
							</li>
						</ul>
					</div>

					<div
						class="flex flex-col items-center xl:items-start text-center xl:text-left"
					>
						<h4
							class="font-extrabold mb-6 text-sm uppercase tracking-wider text-white"
						>
							Socials
						</h4>
						<div
							class="grid grid-cols-2 gap-6 place-items-center xl:place-items-start"
						>
							<a
								href="https://www.instagram.com/theinnerfireofficial/"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
									></path></svg
								>
							</a>
							<a
								href="https://www.youtube.com/@TheInnerFireHQ"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
									></path></svg
								>
							</a>
							<a
								href="https://www.tiktok.com/@theinnerfirehq"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
									></path></svg
								>
							</a>
							<a
								href="https://x.com/TheInnerFireHQ"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
									></path></svg
								>
							</a>
							<a
								href="https://www.threads.com/@theinnerfireofficial"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142l-.126 1.974a11.881 11.881 0 0 0-2.588-.122c-1.066.061-1.94.38-2.6.948-.699.602-1.05 1.394-1.014 2.289.033.818.425 1.504 1.105 1.935.563.357 1.305.538 2.144.524 1.237-.067 2.162-.522 2.75-1.352.588-.83.867-1.948.83-3.324v-.142c-.01-.255-.017-.509-.02-.762.006-1.975.222-3.65.642-4.98.444-1.408 1.185-2.471 2.204-3.163.906-.615 2.007-.927 3.27-.927.66 0 1.35.1 2.05.297l-.464 1.938a5.617 5.617 0 0 0-1.586-.231c-.923 0-1.697.216-2.301.643-.678.48-1.227 1.291-1.632 2.413-.38 1.053-.573 2.339-.573 3.824 0 .13.003.26.01.39.006.13.015.26.026.39.885.64 1.483 1.485 1.778 2.513.638 2.221.367 4.684-1.748 6.862-1.81 1.865-4.088 2.742-7.17 2.767z"
									></path></svg
								>
							</a>
							<a
								href="https://pinterest.com/theinnerfireen/"
								target="_blank"
								class="text-gray-500 hover:text-white transition-colors"
							>
								<svg
									class="w-6 h-6"
									fill="currentColor"
									viewBox="0 0 24 24"
									><path
										d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"
									></path></svg
								>
							</a>
						</div>
					</div>

					<div
						class="flex flex-col items-center xl:items-start text-center xl:text-left"
					>
						<h4
							class="font-extrabold mb-6 text-sm uppercase tracking-wider text-white"
						>
							Stay Updated
						</h4>
						<p class="text-xs text-gray-500 mb-4 leading-relaxed">
							Join men who apply clear systems and build strong
							habits weekly. No filler, no hype—just disciplined
							execution.
						</p>
						<form class="flex flex-col space-y-3 w-full">
							<input
								type="email"
								placeholder="Email Address"
								class="px-4 py-3 rounded-lg border border-gray-800 bg-white/5 text-white focus:outline-none focus:bg-white/10 focus:border-primary-500 transition-all text-xs font-bold tracking-wider uppercase placeholder:text-gray-600 w-full"
							/>
							<button
								type="submit"
								class="btn-primary w-full py-3 text-xs uppercase tracking-widest"
								>Subscribe</button
							>
						</form>
					</div>
				</div>

				<div
					class="border-t border-gray-800 pt-8 flex flex-col items-center text-center space-y-2"
				>
					<p
						class="text-sm font-extrabold uppercase tracking-[0.2em] text-white"
					>
						The Inner Fire
					</p>
					<p
						class="text-[10px] font-extrabold uppercase tracking-widest text-gray-600"
					>
						Copyright © 2026 All Rights Reserved
					</p>
				</div>
			</div>
		</footer>

		<script>
			const btn = document.getElementById("mobile-menu-btn");
			const menu = document.getElementById("mobile-menu");
			let isMenuOpen = false;

			if (btn && menu) {
				btn.addEventListener("click", () => {
					isMenuOpen = !isMenuOpen;
					if (isMenuOpen) {
						menu.classList.remove("translate-x-full");
						btn.innerHTML =
							'<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
						document.body.style.overflow = "hidden";
					} else {
						menu.classList.add("translate-x-full");
						btn.innerHTML =
							'<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
						document.body.style.overflow = "";
					}
				});
			}
		</script>
	</body>
</html>
