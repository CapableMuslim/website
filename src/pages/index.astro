---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { pillarsData } from "../data/pillars";

// 🔥 AUTOMATION: Automatically fetch the 5 most recent posts from content collection
const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return dateB - dateA; // Most recent first
});

const latestPosts = sortedPosts.slice(0, 5).map(post => ({
	title: post.data.title,
	description: post.data.description || "",
	image: post.data.heroImage || "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=800&h=533",
	subpillar: post.data.subpillar || "",
	pillar: post.data.pillar || "",
	slug: post.slug,
}));

// 🔥 AUTOMATION: Organize posts by pillar for dynamic rendering
const postsByPillar = allPosts.reduce((acc, post) => {
	const pillar = post.data.pillar || "GENERAL";
	if (!acc[pillar]) acc[pillar] = [];
	acc[pillar].push({
		title: post.data.title,
		description: post.data.description || "",
		image: post.data.heroImage || "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=800&h=533",
		subpillar: post.data.subpillar || "",
		slug: post.slug,
		pubDate: post.data.pubDate,
	});
	return acc;
}, {} as Record<string, any[]>);

// Sort posts within each pillar by date
Object.keys(postsByPillar).forEach(pillar => {
	postsByPillar[pillar].sort((a, b) => {
		const dateA = a.pubDate ? new Date(a.pubDate).getTime() : 0;
		const dateB = b.pubDate ? new Date(b.pubDate).getTime() : 0;
		return dateB - dateA;
	});
});
---

<BaseLayout title="Home">
	<div>
		{latestPosts.length === 0 ? (
			<section class="py-32 bg-gold-900">
				<div class="container mx-auto px-6 text-center">
					<h1 class="text-4xl lg:text-6xl font-extrabold text-primary-50 uppercase tracking-tight mb-6">
						Capable Muslim
					</h1>
					<p class="text-xl text-gray-400 max-w-2xl mx-auto mb-8">
						Content is being forged. Check back soon for protocols that optimize every domain of your life.
					</p>
				</div>
			</section>
		) : latestPosts.length >= 5 ? (
		<section class="py-6 bg-gold-900">
			<div class="container mx-auto px-6">
				<div class="mb-6">
					<h2
						class="text-3xl lg:text-4xl font-extrabold text-primary-50 uppercase tracking-tight"
					>
						Latest Posts
					</h2>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
					<div class="space-y-4">
						<a
							href={`/posts/${latestPosts[0].slug}`}
							class="group block"
						>
							<div
								class="relative rounded-2xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all"
							>
								<div class="relative h-48 overflow-hidden">
									<img
										src={latestPosts[0].image}
										alt={latestPosts[0].title}
										class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
									/>
									<div class="absolute top-4 left-4">
										<span
											class="px-3 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[10px] font-extrabold uppercase tracking-wider rounded"
										>
											{latestPosts[0].subpillar}
										</span>
									</div>
									<div
										class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
									>
									</div>
								</div>
								<div class="p-4">
									<h3
										class="text-base font-extrabold text-primary-50 mb-2 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight"
									>
										{latestPosts[0].title}
									</h3>
									<p
										class="text-gray-400 text-xs leading-relaxed line-clamp-2"
									>
										{latestPosts[0].description}
									</p>
								</div>
							</div>
						</a>

						<a
							href={`/posts/${latestPosts[1].slug}`}
							class="group block"
						>
							<div
								class="relative rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all"
							>
								<div class="relative h-32 overflow-hidden">
									<img
										src={latestPosts[1].image}
										alt={latestPosts[1].title}
										class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
									/>
									<div class="absolute top-3 left-3">
										<span
											class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded"
										>
											{latestPosts[1].subpillar}
										</span>
									</div>
									<div
										class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"
									>
									</div>
								</div>
								<div class="p-3">
									<h3
										class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight"
									>
										{latestPosts[1].title}
									</h3>
									<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
										{latestPosts[1].description}
									</p>
								</div>
							</div>
						</a>
					</div>

					<div class="space-y-4">
						{
							latestPosts.slice(2).map((post) => (
								<a
									href={`/posts/${post.slug}`}
									class="group block"
								>
									<div class="relative h-full rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
										<div class="relative h-32 overflow-hidden">
											<img
												src={post.image}
												alt={post.title}
												class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
											/>
											<div class="absolute top-3 left-3">
												<span class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded">
													{post.subpillar}
												</span>
											</div>
											<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
										</div>
										<div class="p-3">
											<h3 class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
												{post.title}
											</h3>
											<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
												{post.description}
											</p>
										</div>
									</div>
								</a>
							))
						}
					</div>
				</div>
			</div>
		</section>
		) : null}

		{
			pillarsData.filter(p => p.name !== 'BOOKSHELF').map((pillar, index) => {
				const isEven = index % 2 !== 0;

				// 🔥 AUTOMATION: Use real posts from content collection filtered by pillar
				const pillarPosts = postsByPillar[pillar.name] || [];

				// Skip pillar if no posts exist
				if (pillarPosts.length === 0) return null;

				// Get up to 5 posts for this pillar only
				const displayPosts = pillarPosts.slice(0, 5);
				const mainPost = displayPosts[0];
				const secondPost = displayPosts[1] || null;
				const smallPosts = displayPosts.slice(2, 5);

				return (
					<section class="py-12 lg:py-16 bg-brand-900/75 border-t border-brand-800/45">
						<div class="container mx-auto px-6">
							<div class="mb-8">
								<div class="flex items-center justify-between mb-6">
									<a
										href={`/pillars/${pillar.slug}`}
										class="text-3xl lg:text-4xl font-extrabold text-primary-50 hover:text-gold-300 uppercase tracking-tight transition-colors"
									>
										{pillar.name}
									</a>
									<a
										href={`/pillars/${pillar.slug}`}
										class="text-sm font-bold text-gold-400 hover:text-gold-300 uppercase tracking-wider transition-colors flex items-center gap-2"
									>
										Browse All {pillar.name}
										<svg
											class="w-4 h-4"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M9 5l7 7-7 7"
											/>
										</svg>
									</a>
								</div>

								<div class="flex flex-wrap gap-3">
									{pillar.subpillars.map((subpillar) => (
										<a
											href={`/pillars/${pillar.slug}/${subpillar.toLowerCase().replace(/ /g, "-")}`}
											class="px-4 py-2 bg-white/5 hover:bg-gold-500 border border-brand-800/50 hover:border-gold-400 rounded-lg text-xs font-bold text-gray-400 hover:text-brand-950 uppercase tracking-wider transition-all"
										>
											{subpillar}
										</a>
									))}
								</div>
							</div>

							<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
								{isEven ? (
									<>
										<div class="space-y-4">
											<a
												href={`/posts/${mainPost.slug}`}
												class="group block"
											>
												<div class="relative rounded-2xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
													<div class="relative h-48 overflow-hidden">
														<img
															src={mainPost.image}
															alt={mainPost.title}
															class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
														/>
														<div class="absolute top-4 left-4">
															<span class="px-3 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[10px] font-extrabold uppercase tracking-wider rounded">
																{
																	mainPost.subpillar
																}
															</span>
														</div>
														<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
													</div>
													<div class="p-4">
														<h3 class="text-base font-extrabold text-primary-50 mb-2 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
															{mainPost.title}
														</h3>
														{mainPost.description && (
															<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																{mainPost.description}
															</p>
														)}
													</div>
												</div>
											</a>

											{secondPost && (
												<a
													href={`/posts/${secondPost.slug}`}
													class="group block"
												>
													<div class="relative rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
														<div class="relative h-32 overflow-hidden">
															<img
																src={
																	secondPost.image
																}
																alt={
																	secondPost.title
																}
																class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
															/>
															<div class="absolute top-3 left-3">
																<span class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded">
																	{
																		secondPost.subpillar
																	}
																</span>
															</div>
															<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
														</div>
														<div class="p-3">
															<h3 class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
																{secondPost.title}
															</h3>
															{secondPost.description && (
																<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																	{secondPost.description}
																</p>
															)}
														</div>
													</div>
												</a>
											)}
										</div>

										<div class="space-y-4">
											{smallPosts.map((post) => (
												<a
													href={`/posts/${post.slug}`}
													class="group block"
												>
													<div class="relative h-full rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
														<div class="relative h-32 overflow-hidden">
															<img
																src={post.image}
																alt={post.title}
																class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
															/>
															<div class="absolute top-3 left-3">
																<span class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded">
																	{
																		post.subpillar
																	}
																</span>
															</div>
															<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
														</div>
														<div class="p-3">
															<h3 class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
																{post.title}
															</h3>
															{post.description && (
																<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																	{post.description}
																</p>
															)}
														</div>
													</div>
												</a>
											))}
										</div>
									</>
								) : (
									<>
										<div class="space-y-4">
											{smallPosts.map((post) => (
												<a
													href={`/posts/${post.slug}`}
													class="group block"
												>
													<div class="relative h-full rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
														<div class="relative h-32 overflow-hidden">
															<img
																src={post.image}
																alt={post.title}
																class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
															/>
															<div class="absolute top-3 left-3">
																<span class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded">
																	{
																		post.subpillar
																	}
																</span>
															</div>
															<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
														</div>
														<div class="p-3">
															<h3 class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
																{post.title}
															</h3>
															{post.description && (
																<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																	{post.description}
																</p>
															)}
														</div>
													</div>
												</a>
											))}
										</div>

										<div class="space-y-4">
											<a
												href={`/posts/${mainPost.slug}`}
												class="group block"
											>
												<div class="relative rounded-2xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
													<div class="relative h-48 overflow-hidden">
														<img
															src={mainPost.image}
															alt={mainPost.title}
															class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
														/>
														<div class="absolute top-4 left-4">
															<span class="px-3 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[10px] font-extrabold uppercase tracking-wider rounded">
																{
																	mainPost.subpillar
																}
															</span>
														</div>
														<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
													</div>
													<div class="p-4">
														<h3 class="text-base font-extrabold text-primary-50 mb-2 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
															{mainPost.title}
														</h3>
														{mainPost.description && (
															<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																{mainPost.description}
															</p>
														)}
													</div>
												</div>
											</a>

											{secondPost && (
												<a
													href={`/posts/${secondPost.slug}`}
													class="group block"
												>
													<div class="relative rounded-xl overflow-hidden bg-brand-900/72 border border-brand-800/45 hover:border-gold-400/30 transition-all">
														<div class="relative h-32 overflow-hidden">
															<img
																src={
																	secondPost.image
																}
																alt={
																	secondPost.title
																}
																class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
															/>
															<div class="absolute top-3 left-3">
																<span class="px-2 py-1 bg-gold-500/90 backdrop-blur-sm text-brand-950 text-[9px] font-extrabold uppercase tracking-wider rounded">
																	{
																		secondPost.subpillar
																	}
																</span>
															</div>
															<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
														</div>
														<div class="p-3">
															<h3 class="text-sm font-extrabold text-primary-50 mb-1 group-hover:text-gold-300 transition-colors uppercase tracking-tight leading-tight">
																{secondPost.title}
															</h3>
															{secondPost.description && (
																<p class="text-gray-400 text-xs leading-relaxed line-clamp-2">
																	{secondPost.description}
																</p>
															)}
														</div>
													</div>
												</a>
											)}
										</div>
									</>
								)}
							</div>
						</div>
					</section>
				);
			})
		}
	</div>
</BaseLayout>
