---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import FeaturedArticles from '../components/landing/FeaturedArticles.astro';
import ContentPillars from '../components/landing/ContentPillars.astro';
import Philosophy from '../components/landing/Philosophy.astro';
import NewsletterSection from '../components/landing/NewsletterSection.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import { getCollection } from 'astro:content';
import { featuredSlugs } from '../data/landing';
import { getFeaturedPosts } from '../lib/posts';

const allPosts = await getCollection('posts');
const featuredPosts = getFeaturedPosts(allPosts, featuredSlugs, 6);
---

<BaseLayout
	title="Home"
	description="The Capable Muslim — a practical knowledge platform helping Muslim men become healthier, stronger, wiser, and more capable through faith, discipline, and applied knowledge."
>
	<div class="home-justify">
		<Hero />
		<FeaturedArticles posts={featuredPosts} />
	</div>
	<ContentPillars />
	<div class="home-justify">
		<Philosophy />
		<NewsletterSection />
	</div>
	<FAQSection />
</BaseLayout>
