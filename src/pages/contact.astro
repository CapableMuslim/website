---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';

const { social, email } = siteConfig;

const socialLinks = [
    { name: 'Instagram', href: social.instagram },
    { name: 'YouTube', href: social.youtube },
    { name: 'TikTok', href: social.tiktok },
    { name: 'X / Twitter', href: social.x },
    { name: 'Threads', href: social.threads },
    { name: 'Pinterest', href: social.pinterest },
];
---

<BaseLayout title="Contact">
    <section class="section-padding section-surface">
        <div class="container-content">
            <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
                <!-- Left column -->
                <div class="lg:sticky lg:top-28 lg:self-start">
                    <header class="page-header !mb-8 !pb-0 !border-0">
                        <p class="eyebrow mb-3">Contact</p>
                        <h1 class="page-title">Get In Touch</h1>
                        <p class="page-lead !mt-3">
                            Connect with us through social media, or reach out directly for technical support,
                            billing inquiries, and partnership opportunities.
                        </p>
                    </header>

                    <div class="card mb-8 p-6">
                        <h2 class="font-display text-lg text-parchment">Before You Write</h2>
                        <p class="mt-3 text-sm leading-relaxed text-parchment-300">
                            Please review the <a href="/faq" class="font-semibold text-gold hover:text-gold-300 underline">FAQ content</a> first. We prioritize efficiency and clarity. Questions already answered in documentation may not receive a response.
                        </p>
                    </div>

                    <div>
                        <h2 class="mb-4 font-display text-lg text-parchment">Connect on Social</h2>
                        <div class="grid grid-cols-2 gap-3">
                            {
                                socialLinks.map((link) => (
                                    <a
                                        href={link.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="card group flex items-center justify-center px-4 py-3 text-sm font-semibold text-parchment-300 transition-colors hover:border-gold/30 hover:text-gold"
                                    >
                                        {link.name}
                                    </a>
                                ))
                            }
                        </div>
                    </div>

                    <div class="mt-8 border-t border-gold/10 pt-8">
                        <p class="text-sm text-parchment-400">Or email us directly:</p>
                        <a href={`mailto:${email}`} class="mt-2 inline-block font-semibold text-gold hover:text-gold-300">
                            {email}
                        </a>
                    </div>
                </div>

                <!-- Right column -->
                <div class="card p-6 sm:p-8">
                    <h2 class="font-display text-xl text-parchment">Contact Form</h2>
                    <p class="mt-3 text-sm leading-relaxed text-parchment-300">
                        For technical support, billing inquiries, or partnership opportunities, please use the
                        form below. We aim to respond within 48 hours.
                    </p>

                    <form class="mt-8 space-y-5">
                        <div class="grid gap-5 sm:grid-cols-2">
                            <div>
                                <label for="name" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-gold">
                                    Name
                                </label>
                                <input type="text" id="name" class="input-field" required />
                            </div>
                            <div>
                                <label for="email" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-gold">
                                    Email
                                </label>
                                <input type="email" id="email" class="input-field" required />
                            </div>
                        </div>
                        <div>
                            <label for="subject" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-gold">
                                Subject
                            </label>
                            <input type="text" id="subject" class="input-field" required />
                        </div>
                        <div>
                            <label for="message" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-gold">
                                Message
                            </label>
                            <textarea id="message" rows="8" class="input-field resize-none" required />
                        </div>
                        <button type="submit" class="btn-primary w-full sm:w-auto">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
