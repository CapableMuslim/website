---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformIcon from '../components/community/PlatformIcon.astro';
import { connectPlatforms } from '../data/community';
import { siteConfig } from '../data/site';

const { email } = siteConfig;
---

<BaseLayout title="Contact">
    <section class="section-surface !py-8 sm:!py-10 lg:!py-12">
        <div class="container-content">
            <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch lg:gap-12">
                <!-- Left column -->
                <div>
                    <header class="page-header !mb-5 !pb-0 !border-0">
                        <p class="eyebrow mb-2">Contact</p>
                        <h1 class="page-title">Get In Touch</h1>
                        <p class="page-lead !mt-2">
                            Connect with us through social media, or reach out directly for technical support,
                            billing inquiries, and partnership opportunities.
                        </p>
                    </header>

                    <div class="card mb-6 p-5">
                        <h2 class="font-display text-lg text-parchment">Before You Write</h2>
                        <p class="mt-2 text-sm leading-relaxed text-parchment-300">
                            Please review the <a href="/faq" class="font-semibold text-gold hover:text-gold-300 underline">FAQ content</a> first. We prioritize efficiency and clarity. Questions already answered in documentation may not receive a response.
                        </p>
                    </div>

                    <div>
                        <h2 class="mb-3 font-display text-lg text-parchment">Connect on Social</h2>
                        <ul class="grid grid-cols-4 gap-2">
                            {
                                connectPlatforms.map((platform) => (
                                    <li class="min-w-0">
                                        <a
                                            href={platform.href}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="card group flex h-full min-w-0 flex-col items-center p-2 text-center transition-colors hover:border-gold/30 sm:p-2.5"
                                            aria-label={`Visit ${platform.name}`}
                                        >
                                            <div
                                                class="mb-1.5 flex h-7 w-7 shrink-0 items-center justify-center rounded bg-gold/10 text-gold transition-colors group-hover:bg-gold/15 sm:h-8 sm:w-8"
                                                aria-hidden="true"
                                            >
                                                <PlatformIcon id={platform.id} class="h-4 w-4 sm:h-[18px] sm:w-[18px]" />
                                            </div>
                                            <span class="text-[10px] font-semibold leading-tight text-parchment-300 transition-colors group-hover:text-gold sm:text-xs">
                                                {platform.name}
                                            </span>
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div class="mt-6 border-t border-gold/10 pt-6">
                        <p class="text-sm text-parchment-400">Or email us directly:</p>
                        <a href={`mailto:${email}`} class="mt-1 inline-block font-semibold text-gold hover:text-gold-300">
                            {email}
                        </a>
                    </div>
                </div>

                <!-- Right column -->
                <div class="card flex h-full min-h-0 flex-col p-5 sm:p-6">
                    <h2 class="font-display text-xl text-parchment">Contact Form</h2>
                    <p class="mt-2 text-sm leading-relaxed text-parchment-300">
                        For technical support, billing inquiries, or partnership opportunities, please use the
                        form below. We aim to respond within 48 hours.
                    </p>

                    <form class="mt-5 flex min-h-0 flex-1 flex-col gap-4">
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <label for="name" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gold">
                                    Name
                                </label>
                                <input type="text" id="name" class="input-field" required />
                            </div>
                            <div>
                                <label for="email" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gold">
                                    Email
                                </label>
                                <input type="email" id="email" class="input-field" required />
                            </div>
                        </div>
                        <div>
                            <label for="subject" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gold">
                                Subject
                            </label>
                            <input type="text" id="subject" class="input-field" required />
                        </div>
                        <div class="flex min-h-0 flex-1 flex-col">
                            <label for="message" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gold">
                                Message
                            </label>
                            <textarea id="message" rows="6" class="input-field h-full min-h-[9rem] flex-1 resize-none lg:min-h-[10rem]" required />
                        </div>
                        <button type="submit" class="btn-primary w-full shrink-0 sm:w-auto">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
