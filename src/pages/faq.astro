---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQComponent from '../components/FAQ.tsx';
import { siteConfig } from '../data/site';
import { withBase } from '../lib/paths';
---

<BaseLayout title="FAQ">
    <section class="section-padding section-surface">
        <div class="container-content">
            <header class="page-header text-center">
                <p class="eyebrow mb-3">FAQ</p>
                <h1 class="page-title">{siteConfig.name} FAQ</h1>
                <p class="page-lead mx-auto text-gold">
                    Clarity over noise. Systems over inspiration.
                </p>
            </header>

            <FAQComponent client:visible />

            <div class="card mt-12 p-8 text-center sm:p-10">
                <h2 class="font-display text-xl text-parchment">Personalized Support</h2>
                <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-parchment-300">
                    If your question is technical or relates to billing, our support team is available.
                    Please prioritize using the system first.
                </p>
                <a href={withBase('/contact')} class="btn-primary mt-6 inline-flex">Contact Support</a>
            </div>
        </div>
    </section>
</BaseLayout>
