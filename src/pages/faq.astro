---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQComponent from "../components/FAQ.tsx";
---

<BaseLayout title="FAQ">
	<section class="py-20 lg:py-32 bg-[#050505]">
		<div class="container mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-20 animate-slide-up">
				<h1
					class="text-4xl lg:text-5xl font-extrabold mb-4 text-white uppercase tracking-tight"
				>
					The Inner Fire FAQ
				</h1>
				<p class="text-lg text-primary-500 font-medium tracking-wide">
					Clarity over noise. Systems over inspiration.
				</p>
			</div>

			<div class="max-w-4xl mx-auto">
				<div
					class="border border-white/5 rounded-2xl bg-[#080808] p-8 shadow-2xl"
				>
					<FAQComponent client:visible />
				</div>
			</div>

			<div class="mt-32 max-w-4xl mx-auto">
				<div
					class="bg-[#0a0a0a] border border-white/5 p-12 text-center rounded-2xl relative overflow-hidden group hover:border-primary-900/40 transition-colors"
				>
					<div
						class="absolute inset-0 bg-primary-900/5 opacity-0 group-hover:opacity-100 transition-opacity"
					>
					</div>
					<h3
						class="text-2xl font-bold text-white mb-4 relative z-10"
					>
						Personalized Support
					</h3>
					<p
						class="text-gray-400 mb-8 max-w-lg mx-auto text-sm leading-relaxed relative z-10"
					>
						If your question is technical or relates to billing, our
						support team is available. Please prioritize using the
						system first.
					</p>
					<a
						href="/contact"
						class="relative z-10 inline-flex items-center justify-center px-8 py-3 bg-white text-black hover:bg-primary-500 hover:text-white font-black uppercase tracking-[0.2em] rounded-none transition-all duration-300 text-xs"
					>
						Contact Support
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
