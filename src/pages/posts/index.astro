---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticlesPage from '../../components/ArticlesPage.tsx';
import { getCollection } from 'astro:content';
import { sortPostsByDate, toPostCard } from '../../lib/posts';

const allPosts = await getCollection('posts');
const posts = sortPostsByDate(allPosts).map(toPostCard);
---

<BaseLayout
    title="All Articles"
    description="Browse every article on The Capable Muslim — practical guides on health, faith, discipline, and capability."
>
    <section class="section-padding section-surface">
        <div class="container-content">
            <header class="page-header">
                <p class="eyebrow mb-3">Articles</p>
                <h1 class="page-title">All articles</h1>
                <p class="page-lead">
                    Every guide, framework, and insight published on The Capable Muslim. Filter by category
                    to explore a specific domain.
                </p>
            </header>

            <ArticlesPage client:load posts={posts} />
        </div>
    </section>
</BaseLayout>
