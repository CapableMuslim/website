---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticlesFilter from '../../components/ArticlesFilter.tsx';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import { pillarsData } from '../../data/pillars';
import { getCollection } from 'astro:content';
import { sortPostsByDate, toPostCard } from '../../lib/posts';

const allPosts = await getCollection('posts');
const posts = sortPostsByDate(allPosts).map(toPostCard);

const keysWithPosts = new Set(posts.map((p) => p.pillarKey));
const categories = pillarsData
    .filter((p) => p.slug !== 'bookshelf' && keysWithPosts.has(p.name))
    .map((p) => ({
        key: p.name,
        label: p.name.charAt(0) + p.name.slice(1).toLowerCase(),
    }));
---

<BaseLayout
    title="All Articles"
    description="Browse every article on The Capable Muslim — practical guides on health, faith, discipline, and capability."
>
    <section class="section-padding section-surface">
        <div class="container-content">
            <header class="page-header">
                <p class="eyebrow mb-3">Articles</p>
                <h1 class="page-title">All articles</h1>
                <p class="page-lead">
                    Every guide, framework, and insight published on The Capable Muslim. Filter by category
                    to explore a specific domain.
                </p>
            </header>

            <ArticlesFilter client:load categories={categories} />

            <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {
                    posts.map((post) => (
                        <li data-article-pillar={post.pillarKey}>
                            <ArticleCard post={post} variant="default" />
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>
</BaseLayout>
