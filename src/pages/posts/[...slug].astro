---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((entry) => ({
        params: { slug: entry.slug },
        props: entry,
    }));
}

const post = Astro.props;
const { Content, headings } = await post.render();
const { social } = siteConfig;

const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);

const allPosts = (await getCollection("posts")).sort((a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
    return dateB - dateA;
});

const currentIndex = allPosts.findIndex((entry) => entry.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const defaultImage =
    "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=800&h=533";

let relatedPosts = allPosts
    .filter((entry) => entry.slug !== post.slug && entry.data.pillar === post.data.pillar)
    .slice(0, 3);

if (relatedPosts.length < 3) {
    const fillers = allPosts
        .filter(
            (entry) =>
                entry.slug !== post.slug &&
                !relatedPosts.some((related) => related.slug === entry.slug),
        )
        .slice(0, 3 - relatedPosts.length);
    relatedPosts = [...relatedPosts, ...fillers];
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
    <aside class="fixed right-6 top-28 z-50 hidden xl:flex flex-col gap-3 w-44">
        {
            tocHeadings.length > 0 && (
                <nav
                    aria-label="On this page"
                    class="bg-brand-800/90 border border-gold-500/20 rounded-2xl p-3 shadow-gold backdrop-blur-sm max-h-[36vh] overflow-y-auto"
                >
                    <h2 class="text-xs font-extrabold uppercase tracking-[0.2em] text-gold-400 mb-3">
                        On this page
                    </h2>
                    <ul class="space-y-2">
                        {tocHeadings.map((heading) => (
                            <li class={heading.depth === 3 ? "ml-3" : ""}>
                                <a
                                    href={`#${heading.slug}`}
                                    class="text-xs text-primary-200 hover:text-gold-300 transition-colors leading-snug block"
                                >
                                    {heading.text}
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            )
        }

        <div class="bg-brand-800/90 border border-primary-400/20 rounded-2xl p-3 shadow-metallic backdrop-blur-sm">
            <h3 class="text-[10px] font-bold text-primary-200 uppercase tracking-wider text-center mb-3 px-1 leading-tight">
                Follow us on<br />Social media
            </h3>
            <div class="grid grid-cols-2 gap-2">
                <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="Instagram">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
                <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="YouTube">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
                <a href={social.tiktok} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="TikTok">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </a>
                <a href={social.x} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="X / Twitter">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href={social.threads} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="Threads">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142l-.126 1.974a11.881 11.881 0 0 0-2.588-.122c-1.066.061-1.94.38-2.6.948-.699.602-1.05 1.394-1.014 2.289.033.818.425 1.504 1.105 1.935.563.357 1.305.538 2.144.524 1.237-.067 2.162-.522 2.75-1.352.588-.83.867-1.948.83-3.324v-.142c-.01-.255-.017-.509-.02-.762.006-1.975.222-3.65.642-4.98.444-1.408 1.185-2.471 2.204-3.163.906-.615 2.007-.927 3.27-.927.66 0 1.35.1 2.05.297l-.464 1.938a5.617 5.617 0 0 0-1.586-.231c-.923 0-1.697.216-2.301.643-.678.48-1.227 1.291-1.632 2.413-.38 1.053-.573 2.339-.573 3.824 0 .13.003.26.01.39.006.13.015.26.026.39.885.64 1.483 1.485 1.778 2.513.638 2.221.367 4.684-1.748 6.862-1.81 1.865-4.088 2.742-7.17 2.767z"/></svg>
                </a>
                <a href={social.pinterest} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-10 h-10 bg-brand-900/50 hover:bg-gold-500/20 border border-primary-400/15 hover:border-gold-400/40 rounded-lg transition-all" aria-label="Pinterest">
                    <svg class="w-4 h-4 text-primary-400 group-hover:text-gold-200 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
                </a>
            </div>
        </div>
    </aside>

    <article class="min-h-screen bg-brand-950">
        {
            post.data.heroImage && (
                <div class="relative w-full h-[60vh] lg:h-[70vh] overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-950/50 to-brand-950" />
                    <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" />
                    <div class="absolute bottom-0 left-0 right-0 px-6 pb-12 lg:pb-16">
                        <div class="container mx-auto max-w-4xl">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="px-3 py-1 bg-gold-500/90 text-brand-950 text-xs font-extrabold uppercase tracking-wider rounded">
                                    {post.data.pillar}
                                </span>
                                <span class="text-primary-300 text-xs">/</span>
                                <span class="px-3 py-1 bg-primary-400/15 text-primary-100 text-xs font-extrabold uppercase tracking-wider rounded border border-primary-400/20">
                                    {post.data.subpillar}
                                </span>
                            </div>
                            <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-black text-white uppercase tracking-tight leading-[1.1] mb-4 break-words">
                                {post.data.title}
                            </h1>
                            {post.data.description && (
                                <p class="text-lg lg:text-xl text-primary-100 font-normal max-w-3xl">
                                    {post.data.description}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            )
        }

        {
            !post.data.heroImage && (
                <div class="pt-32 pb-16 px-6 bg-brand-950">
                    <div class="container mx-auto max-w-4xl">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="px-3 py-1 bg-gold-500/90 text-brand-950 text-xs font-extrabold uppercase tracking-wider rounded">
                                {post.data.pillar}
                            </span>
                            <span class="text-primary-300 text-xs">/</span>
                            <span class="px-3 py-1 bg-primary-400/15 text-primary-100 text-xs font-extrabold uppercase tracking-wider rounded border border-primary-400/20">
                                {post.data.subpillar}
                            </span>
                        </div>
                        <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-black text-white uppercase tracking-tight leading-[1.1] mb-6 break-words">
                            {post.data.title}
                        </h1>
                        {post.data.description && (
                            <p class="text-lg lg:text-xl text-primary-100 font-normal max-w-3xl">
                                {post.data.description}
                            </p>
                        )}
                    </div>
                </div>
            )
        }

        <div class="py-12 lg:py-20 px-6 bg-brand-950">
            <div class="container mx-auto max-w-4xl">
                <div class="bg-brand-800/60 border border-primary-400/15 rounded-2xl p-8 lg:p-12 shadow-metallic">
                    <div class="article-content">
                        <Content />
                    </div>
                </div>

                <nav
                    aria-label="Article navigation"
                    class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4"
                >
                    {
                        prevPost ? (
                            <a
                                href={`/posts/${prevPost.slug}`}
                                class="group flex flex-col justify-center bg-brand-800/50 border border-primary-400/10 hover:border-gold-400/30 rounded-xl p-6 transition-all"
                            >
                                <span class="text-sm font-black uppercase tracking-[0.15em] text-gold-400 mb-3">
                                    &lt;&lt; Previous
                                </span>
                                <span class="text-xs text-white line-clamp-2 leading-relaxed">
                                    {prevPost.data.title}
                                </span>
                            </a>
                        ) : (
                            <div class="hidden sm:block" />
                        )
                    }

                    <a
                        href="/posts"
                        class="flex flex-col items-center justify-center bg-brand-800/50 border border-gold-500/20 hover:border-gold-400/40 rounded-xl p-6 transition-all text-center"
                    >
                        <span class="text-sm font-black uppercase tracking-[0.15em] text-gold-400 mb-2">
                            All Articles
                        </span>
                        <span class="text-xs text-white">Browse library</span>
                    </a>

                    {
                        nextPost ? (
                            <a
                                href={`/posts/${nextPost.slug}`}
                                class="group flex flex-col justify-center sm:items-end bg-brand-800/50 border border-primary-400/10 hover:border-gold-400/30 rounded-xl p-6 transition-all sm:text-right"
                            >
                                <span class="text-sm font-black uppercase tracking-[0.15em] text-gold-400 mb-3">
                                    Next &gt;&gt;
                                </span>
                                <span class="text-xs text-white line-clamp-2 leading-relaxed">
                                    {nextPost.data.title}
                                </span>
                            </a>
                        ) : (
                            <div class="hidden sm:block" />
                        )
                    }
                </nav>

                {
                    relatedPosts.length > 0 && (
                        <section class="mt-16 pt-12 border-t border-gold-500/20">
                            <h2 class="text-2xl font-extrabold text-white uppercase tracking-tight mb-8">
                                Related Articles
                            </h2>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                {relatedPosts.map((related) => (
                                    <a href={`/posts/${related.slug}`} class="group block">
                                        <div class="bg-brand-800/50 border border-primary-400/10 rounded-xl overflow-hidden hover:border-gold-400/30 transition-all">
                                            <div class="relative h-40 overflow-hidden">
                                                <img
                                                    src={related.data.heroImage || defaultImage}
                                                    alt={related.data.title}
                                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                                />
                                                <div class="absolute inset-0 bg-gradient-to-t from-brand-950/80 to-transparent" />
                                            </div>
                                            <div class="p-4">
                                                <h3 class="text-sm font-bold text-white group-hover:text-gold-300 transition-colors leading-snug line-clamp-3">
                                                    {related.data.title}
                                                </h3>
                                            </div>
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </section>
                    )
                }
            </div>
        </div>
    </article>

    <style is:global>
        .article-content {
            color: #e8e8e8;
            line-height: 1.8;
        }

        .article-content h1 {
            font-size: 2.5rem;
            font-weight: 900;
            color: #f0f0f0;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            line-height: 1.1;
            margin-top: 3rem;
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
            border-bottom: 4px solid #c5a572;
            scroll-margin-top: 6rem;
        }

        .article-content h2 {
            font-size: 2rem;
            font-weight: 900;
            color: #c5a572;
            text-transform: uppercase;
            letter-spacing: -0.01em;
            line-height: 1.2;
            margin-top: 2.5rem;
            margin-bottom: 1.5rem;
            scroll-margin-top: 6rem;
        }

        .article-content h3 {
            font-size: 1.5rem;
            font-weight: 800;
            color: #d4d4d8;
            text-transform: uppercase;
            letter-spacing: -0.01em;
            line-height: 1.3;
            margin-top: 2rem;
            margin-bottom: 1rem;
            scroll-margin-top: 6rem;
        }

        .article-content h4 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #e8e8e8;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
            scroll-margin-top: 6rem;
        }

        .article-content p {
            color: #e8e8e8;
            font-size: 1.125rem;
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }

        .article-content p:first-of-type {
            font-size: 1.25rem;
            font-weight: 500;
            color: #f0f0f0;
        }

        .article-content strong,
        .article-content b {
            color: #f5f5f5;
            font-weight: 900;
        }

        .article-content a {
            color: #c5a572;
            font-weight: 600;
            text-decoration: underline;
            transition: color 0.2s;
        }

        .article-content a:hover {
            color: #d4af37;
        }

        .article-content ul,
        .article-content ol {
            color: #e8e8e8;
            font-size: 1.125rem;
            margin-left: 2rem;
            margin-bottom: 1.5rem;
        }

        .article-content li {
            color: #e8e8e8;
            margin-bottom: 0.75rem;
            line-height: 1.8;
        }

        .article-content blockquote {
            border-left: 4px solid #c5a572;
            background: rgba(197, 165, 114, 0.08);
            padding: 1.5rem;
            margin: 2rem 0;
            border-radius: 0 0.5rem 0.5rem 0;
            color: #e8e8e8;
            font-style: italic;
        }

        .article-content code {
            background: rgba(192, 192, 192, 0.12);
            color: #d4af37;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-size: 0.9em;
            font-weight: 600;
        }

        .article-content pre {
            background: #2e261c;
            border: 1px solid rgba(192, 192, 192, 0.15);
            border-radius: 0.75rem;
            padding: 1.5rem;
            overflow-x: auto;
            margin: 2rem 0;
        }

        .article-content img {
            border-radius: 0.75rem;
            border: 1px solid rgba(192, 192, 192, 0.15);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
            margin: 2rem 0;
            width: 100%;
            height: auto;
        }

        .article-content hr {
            border: 0;
            border-top: 2px solid rgba(197, 165, 114, 0.25);
            margin: 3rem 0;
        }

        @media (max-width: 768px) {
            .article-content h1 { font-size: 2rem; }
            .article-content h2 { font-size: 1.5rem; }
            .article-content h3 { font-size: 1.25rem; }
            .article-content p { font-size: 1rem; }
        }
    </style>
</BaseLayout>
