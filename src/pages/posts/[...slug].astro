---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleHero from '../../components/article/ArticleHero.astro';
import ArticleToc from '../../components/article/ArticleToc.astro';
import ArticleFollow from '../../components/article/ArticleFollow.astro';
import ArticleNewsletter from '../../components/article/ArticleNewsletter.astro';
import ArticleRelated from '../../components/article/ArticleRelated.astro';
import ArticleFeedback from '../../components/article/ArticleFeedback.astro';
import ArticlePagination from '../../components/article/ArticlePagination.astro';
import ArticleReadingProgress from '../../components/article/ArticleReadingProgress.astro';
import {
    DEFAULT_HERO_IMAGE,
    estimateReadingTime,
    getRelatedPosts,
    sortPostsByDate,
} from '../../lib/posts';
import '../../styles/article.css';

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    return posts.map((entry) => ({
        params: { slug: entry.slug },
        props: entry,
    }));
}

const post = Astro.props;
const { Content, headings } = await post.render();

const allPosts = sortPostsByDate(await getCollection('posts'));
const readingTime = estimateReadingTime(post.body);
const relatedPosts = getRelatedPosts(allPosts, post, 5);
const hasToc = headings.some((h) => h.depth >= 2 && h.depth <= 3);
const heroImage = post.data.heroImage ?? DEFAULT_HERO_IMAGE;

const currentIndex = allPosts.findIndex((entry) => entry.slug === post.slug);
const prevPost =
    currentIndex < allPosts.length - 1
        ? {
              slug: allPosts[currentIndex + 1].slug,
              title: allPosts[currentIndex + 1].data.title,
              image: allPosts[currentIndex + 1].data.heroImage ?? DEFAULT_HERO_IMAGE,
          }
        : null;
const nextPost =
    currentIndex > 0
        ? {
              slug: allPosts[currentIndex - 1].slug,
              title: allPosts[currentIndex - 1].data.title,
              image: allPosts[currentIndex - 1].data.heroImage ?? DEFAULT_HERO_IMAGE,
          }
        : null;
---

<BaseLayout title={post.data.title} description={post.data.description}>
    <article class="article-page" itemscope itemtype="https://schema.org/Article">
        <meta itemprop="headline" content={post.data.title} />
        {post.data.description && <meta itemprop="description" content={post.data.description} />}
        {post.data.pubDate && (
            <meta itemprop="datePublished" content={post.data.pubDate.toISOString()} />
        )}

        <ArticleHero
            src={heroImage}
            alt={post.data.title}
            pillar={post.data.pillar}
            subpillar={post.data.subpillar}
            title={post.data.title}
            subtitle={post.data.description}
            readingTime={readingTime}
            pubDate={post.data.pubDate}
        />

        <div class="container-content">
            {
                hasToc && (
                    <div class="article-mobile-toc">
                        <details class="article-mobile-toc__details">
                            <summary class="article-mobile-toc__summary">
                                On This Page
                                <svg
                                    class="h-4 w-4 shrink-0 text-parchment-400"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                >
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </summary>
                            <div class="article-mobile-toc__body">
                                <ArticleToc headings={headings} variant="compact" id="article-toc-mobile" />
                                <ArticleFollow />
                                <ArticleNewsletter />
                            </div>
                        </details>
                    </div>
                )
            }

            <div class="article-grid" id="article-grid">
                <aside class="article-sidebar article-sidebar--left" aria-label="Article navigation">
                    <div class="article-sidebar__inner">
                        <ArticleToc headings={headings} id="article-toc-left" />
                        <ArticleFollow />
                        <ArticleNewsletter />
                    </div>
                </aside>

                <div class="article-main">
                    <div class="article-content" itemprop="articleBody">
                        <Content />
                    </div>

                    <ArticlePagination prevPost={prevPost} nextPost={nextPost} />
                    <ArticleFeedback articleSlug={post.slug} articleTitle={post.data.title} />
                    <ArticleRelated posts={relatedPosts} />
                </div>
            </div>
        </div>
    </article>

    <ArticleReadingProgress />

    <script>
        const tocLinks = document.querySelectorAll('[data-toc-link]');
        const headingIds = [...tocLinks].map((link) => link.getAttribute('data-toc-link')).filter(Boolean);

        if (headingIds.length > 0) {
            const observedHeadings = headingIds
                .map((id) => document.getElementById(id!))
                .filter((el): el is HTMLElement => el !== null);

            const setActive = (activeId: string) => {
                tocLinks.forEach((link) => {
                    const slug = link.getAttribute('data-toc-link');
                    link.classList.toggle('is-active', slug === activeId);
                });
            };

            const observer = new IntersectionObserver(
                (entries) => {
                    const visible = entries
                        .filter((e) => e.isIntersecting)
                        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

                    if (visible.length > 0) {
                        setActive(visible[0].target.id);
                    }
                },
                { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
            );

            observedHeadings.forEach((heading) => observer.observe(heading));

            if (observedHeadings[0]) {
                setActive(observedHeadings[0].id);
            }
        }
    </script>
</BaseLayout>
