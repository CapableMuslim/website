---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pillarsData } from "../../../data/pillars";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const paths: any[] = [];

    pillarsData.forEach((pillar) => {
        pillar.subpillars.forEach((subpillar) => {
            paths.push({
                params: {
                    pillar: pillar.slug,
                    subpillar: subpillar.toLowerCase().replace(/ /g, "-"),
                },
                props: {
                    pillarData: pillar,
                    subpillarName: subpillar,
                },
            });
        });
    });

    return paths;
}

const { pillarData, subpillarName } = Astro.props;
const { subpillar } = Astro.params;

// Fetch posts from content collection for this subpillar
const allPosts = await getCollection("posts");
const posts = allPosts
    .filter(post =>
        post.data.pillar === pillarData.name &&
        post.data.subpillar === subpillarName
    )
    .sort((a, b) => {
        const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
        const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
        return dateB - dateA;
    })
    .map(post => ({
        title: post.data.title,
        description: post.data.description || "",
        image: post.data.heroImage || "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=800&h=533",
        subpillar: post.data.subpillar || "",
        slug: post.slug,
    }));

const title = `${subpillarName} | ${pillarData.name} - The Inner Fire`;
const description = `The Inner Fire protocols and insights on ${subpillarName}.`;
---

<BaseLayout title={subpillarName} description={description}>
    <div class="container mx-auto px-6 py-24">
        <div class="mb-12 border-b border-white/10 pb-8">
            <h1
                class="text-2xl lg:text-4xl font-extrabold text-white uppercase tracking-tight mb-4"
            >
                {subpillarName}
            </h1>
            <p class="text-xl text-gray-400 max-w-2xl">
                Curated protocols, guides, and wisdom for {
                    subpillarName.toLowerCase()
                }.
            </p>
        </div>

        {
            posts.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {posts.map((post: any) => (
                        <a
                            href={`/posts/${post.slug}`}
                            class="group block h-full"
                        >
                            <div class="bg-[#0a0a0a] border border-white/10 rounded-2xl overflow-hidden h-full hover:border-primary-500/50 transition-all duration-300 transform group-hover:-translate-y-1">
                                <div class="relative h-48 overflow-hidden">
                                    <img
                                        src={post.image}
                                        alt={post.title}
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent" />
                                    <div class="absolute bottom-4 left-4">
                                        <span class="px-2 py-1 bg-primary-600/90 text-white text-[10px] font-extrabold uppercase tracking-wider rounded">
                                            {post.subpillar}
                                        </span>
                                    </div>
                                </div>
                                <div class="p-6">
                                    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-primary-500 transition-colors leading-tight">
                                        {post.title}
                                    </h3>
                                    {post.description && (
                                        <p class="text-gray-400 text-sm leading-relaxed line-clamp-3">
                                            {post.description}
                                        </p>
                                    )}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="py-20 text-center border border-dashed border-white/10 rounded-2xl">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 mb-6 text-gray-500">
                        <svg
                            class="w-8 h-8"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
                            />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">
                        Protocols Incoming
                    </h3>
                    <p class="text-gray-400 max-w-md mx-auto">
                        We are currently codifying the systems for{" "}
                        {subpillarName}. Check back soon for high-fidelity
                        guides.
                    </p>
                </div>
            )
        }
    </div>
</BaseLayout>
