---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ui/ArticleCard.astro';
import { pillarsData } from '../../../data/pillars';
import { getCollection } from 'astro:content';
import { sortPostsByDate, toPostCard } from '../../../lib/posts';

export async function getStaticPaths() {
    const paths: {
        params: { pillar: string; subpillar: string };
        props: { pillarData: (typeof pillarsData)[number]; subpillarName: string };
    }[] = [];

    pillarsData.forEach((pillar) => {
        pillar.subpillars.forEach((subpillar) => {
            paths.push({
                params: {
                    pillar: pillar.slug,
                    subpillar: subpillar.toLowerCase().replace(/ /g, '-'),
                },
                props: {
                    pillarData: pillar,
                    subpillarName: subpillar,
                },
            });
        });
    });

    return paths;
}

const { pillarData, subpillarName } = Astro.props;

const allPosts = await getCollection('posts');
const posts = sortPostsByDate(
    allPosts.filter(
        (post) => post.data.pillar === pillarData.name && post.data.subpillar === subpillarName,
    ),
).map(toPostCard);

const description = `The Capable Muslim protocols and insights on ${subpillarName}.`;
---

<BaseLayout title={`${subpillarName} | ${pillarData.name}`} description={description}>
    <section class="section-padding section-surface">
        <div class="container-content">
            <header class="page-header">
                <p class="eyebrow mb-3">
                    <a href={`/pillars/${pillarData.slug}`} class="hover:text-gold-300 transition-colors">
                        {pillarData.name}
                    </a>
                </p>
                <h1 class="page-title">{subpillarName}</h1>
                <p class="page-lead">
                    Curated protocols, guides, and wisdom for {subpillarName.toLowerCase()}.
                </p>
            </header>

            {
                posts.length > 0 ? (
                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                        {posts.map((post) => (
                            <ArticleCard post={post} variant="default" />
                        ))}
                    </div>
                ) : (
                    <div class="card py-16 text-center">
                        <h2 class="font-display text-xl text-parchment">Protocols incoming</h2>
                        <p class="mt-2 max-w-md mx-auto text-sm text-parchment-400">
                            We are currently codifying the systems for {subpillarName}. Check back soon for
                            high-fidelity guides.
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</BaseLayout>
