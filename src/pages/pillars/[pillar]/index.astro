---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pillarsData } from "../../../data/pillars";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    return pillarsData.map((pillar) => ({
        params: { pillar: pillar.slug },
        props: { pillarData: pillar },
    }));
}

const { pillarData } = Astro.props;
const { name, subpillars } = pillarData;

// Fetch posts from content collection for this pillar
const allPosts = await getCollection("posts");
const posts = allPosts
    .filter(post => post.data.pillar === name)
    .sort((a, b) => {
        const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
        const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
        return dateB - dateA;
    })
    .map(post => ({
        title: post.data.title,
        description: post.data.description || "",
        image: post.data.heroImage || "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=800&h=533",
        subpillar: post.data.subpillar || "",
        slug: post.slug,
    }));

const pageTitle = `${name} | The Inner Fire`;
const pageDescription = `Master your life with our ${name} protocols and guides.`;
---

<BaseLayout title={name} description={pageDescription}>
    <div class="container mx-auto px-6 py-24">
        <div class="mb-12 border-b border-white/10 pb-8">
            <h1
                class="text-2xl lg:text-4xl font-extrabold text-white uppercase tracking-tight mb-6"
            >
                {name}
            </h1>

            <div class="flex flex-wrap gap-3">
                {
                    subpillars.map((sub) => (
                        <a
                            href={`/pillars/${pillarData.slug}/${sub.toLowerCase().replace(/ /g, "-")}`}
                            class="px-4 py-2 bg-white/5 hover:bg-primary-600 border border-white/10 hover:border-primary-500 rounded-lg text-xs font-bold text-gray-400 hover:text-white uppercase tracking-wider transition-all"
                        >
                            {sub}
                        </a>
                    ))
                }
            </div>
        </div>

        {
            posts.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {posts.map((post) => (
                        <a
                            href={`/posts/${post.slug}`}
                            class="group block h-full"
                        >
                            <div class="bg-[#0a0a0a] border border-white/10 rounded-2xl overflow-hidden h-full hover:border-primary-500/50 transition-all duration-300 transform group-hover:-translate-y-1">
                                <div class="relative h-48 overflow-hidden">
                                    <img
                                        src={post.image}
                                        alt={post.title}
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent" />
                                    <div class="absolute bottom-4 left-4">
                                        <span class="px-2 py-1 bg-primary-600/90 text-white text-[10px] font-extrabold uppercase tracking-wider rounded">
                                            {post.subpillar}
                                        </span>
                                    </div>
                                </div>
                                <div class="p-6">
                                    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-primary-500 transition-colors leading-tight">
                                        {post.title}
                                    </h3>
                                    {post.description && (
                                        <p class="text-gray-400 text-sm leading-relaxed line-clamp-3">
                                            {post.description}
                                        </p>
                                    )}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="py-20 text-center border border-dashed border-white/10 rounded-2xl">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 mb-6 text-gray-500">
                        <svg
                            class="w-8 h-8"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">
                        Library Growing
                    </h3>
                    <p class="text-gray-400 max-w-md mx-auto">
                        We are actively curating the high-performance protocols
                        for {name}. Check back soon.
                    </p>
                </div>
            )
        }
    </div>
</BaseLayout>
