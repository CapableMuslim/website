---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ui/ArticleCard.astro';
import { pillarsData } from '../../../data/pillars';
import { getCollection } from 'astro:content';
import { sortPostsByDate, toPostCard } from '../../../lib/posts';
import { withBase } from '../../../lib/paths';

export async function getStaticPaths() {
    return pillarsData.map((pillar) => ({
        params: { pillar: pillar.slug },
        props: { pillarData: pillar },
    }));
}

const { pillarData } = Astro.props;
const { name, subpillars } = pillarData;

const allPosts = await getCollection('posts');
const posts = sortPostsByDate(allPosts.filter((post) => post.data.pillar === name)).map(toPostCard);

const pageDescription = `Master your life with our ${name} protocols and guides.`;
---

<BaseLayout title={name} description={pageDescription}>
    <section class="section-padding section-surface">
        <div class="container-content">
            <header class="page-header">
                <p class="eyebrow mb-3">Pillar</p>
                <h1 class="page-title">{name}</h1>
                <p class="page-lead">
                    Articles, protocols, and guides for building capability in {name.toLowerCase()}.
                </p>
            </header>

            {
                subpillars.length > 0 && (
                    <div class="mb-10 flex flex-wrap gap-2">
                        {subpillars.map((sub) => (
                            <a
                                href={withBase(`/pillars/${pillarData.slug}/${sub.toLowerCase().replace(/ /g, '-')}`)}
                                class="rounded border border-gold/20 bg-bronze-950/40 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-parchment-300 transition-colors hover:border-gold/40 hover:text-gold"
                            >
                                {sub}
                            </a>
                        ))}
                    </div>
                )
            }

            {
                posts.length > 0 ? (
                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                        {posts.map((post) => (
                            <ArticleCard post={post} variant="default" />
                        ))}
                    </div>
                ) : (
                    <div class="card py-16 text-center">
                        <h2 class="font-display text-xl text-parchment">Library growing</h2>
                        <p class="mt-2 max-w-md mx-auto text-sm text-parchment-400">
                            We are actively curating the high-performance protocols for {name}. Check back soon.
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</BaseLayout>
