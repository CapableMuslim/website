---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformIcon from '../components/community/PlatformIcon.astro';
import {
    socialPlatforms,
    communityPlatforms,
    communityMemberCount,
} from '../data/community';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const articleCount = posts.length;

const stats = [
    { label: 'Social Platforms', value: String(socialPlatforms.length) },
    { label: 'Community Platforms', value: String(communityPlatforms.length) },
    { label: 'Members', value: communityMemberCount },
    { label: 'Articles Published', value: String(articleCount) },
];
---

<BaseLayout
    title="Community"
    description="Follow The Capable Muslim, join our communities, and grow alongside others pursuing health, discipline, faith, and capability."
>
    <!-- Hero -->
    <section class="section-padding-sm border-b border-gold/10 bg-bronze-950">
        <div class="container-content">
            <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-14">
                <header class="page-header mb-0 max-w-xl border-0 pb-0">
                    <p class="eyebrow mb-3">Community</p>
                    <h1 class="page-title">Grow Together</h1>
                    <p class="page-lead">
                        Learning is better together. Follow our content, join our communities, and become
                        part of a growing movement dedicated to becoming healthier, stronger, wiser, and
                        more capable.
                    </p>
                </header>

                <dl class="grid grid-cols-2 gap-3 lg:max-w-md lg:justify-self-end">
                    {
                        stats.map((stat) => (
                            <div class="card p-3 sm:p-4">
                                <dt class="text-[10px] font-semibold uppercase tracking-[0.12em] text-parchment-400 sm:text-xs">
                                    {stat.label}
                                </dt>
                                <dd class="mt-1.5 font-display text-xl text-parchment sm:text-2xl">
                                    {stat.value}
                                </dd>
                            </div>
                        ))
                    }
                </dl>
            </div>
        </div>
    </section>

    <!-- Communities & Social -->
    <section
        id="communities"
        class="border-b border-gold/10 bg-bronze-800/80 pt-8 pb-12 sm:pt-10 sm:pb-14 lg:pt-10 lg:pb-16"
        aria-labelledby="join-heading"
    >
        <div class="container-content">
            <div class="grid gap-12 lg:grid-cols-2 lg:grid-rows-[auto_1fr] lg:gap-x-16 lg:gap-y-6">
                <!-- Left: Communities -->
                <header class="order-1 border-b border-gold/10 pb-5 lg:col-start-1 lg:row-start-1">
                    <p class="eyebrow mb-2">Stay connected</p>
                    <h2 id="join-heading" class="font-display text-xl text-parchment sm:text-2xl">Join Our Communities</h2>
                    <p class="mt-3 text-sm leading-relaxed text-parchment-300">
                        Become part of the conversation, ask questions, share experiences, and grow
                        alongside others pursuing the same mission.
                    </p>
                </header>

                <ul id="community-list" class="order-2 flex flex-col gap-4 lg:col-start-1 lg:row-start-2 lg:min-h-0 lg:justify-between lg:gap-0">
                    {
                        communityPlatforms.map((platform) => (
                            <li class="lg:flex lg:min-h-0 lg:flex-1 lg:flex-col">
                                <article
                                    class="group flex h-full flex-col rounded-lg border border-silver/20 bg-bronze-900/50 p-4 shadow-card transition-all duration-200 hover:border-silver/35 hover:shadow-elevated sm:p-5"
                                >
                                    <div class="flex items-center gap-4">
                                        <div
                                            class="flex h-10 w-10 shrink-0 items-center justify-center rounded bg-silver/10 text-silver transition-all duration-200 group-hover:scale-105 group-hover:bg-silver/15"
                                            aria-hidden="true"
                                        >
                                            <PlatformIcon id={platform.id} />
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <h4 class="font-display text-lg font-bold text-parchment">
                                                {platform.name}
                                            </h4>
                                            <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-parchment-300">
                                                {platform.description}
                                            </p>
                                        </div>
                                    </div>
                                    {
                                        platform.comingSoon ? (
                                            <span
                                                class="btn mt-auto pt-4 w-full cursor-default border border-silver/20 bg-transparent text-center text-parchment-400 sm:ml-14 sm:w-auto"
                                                aria-label={`${platform.name} coming soon`}
                                            >
                                                Coming soon
                                            </span>
                                        ) : (
                                            <a
                                                href={platform.href}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="btn mt-auto pt-4 w-full border border-silver/30 bg-transparent text-center text-parchment transition-colors duration-200 hover:border-silver/50 hover:bg-silver/10 sm:ml-14 sm:w-auto"
                                                aria-label={`${platform.cta} ${platform.name} community`}
                                            >
                                                {platform.cta}
                                            </a>
                                        )
                                    }
                                </article>
                            </li>
                        ))
                    }
                </ul>

                <!-- Right: Social media -->
                <header class="order-3 border-b border-gold/10 pb-5 lg:col-start-2 lg:row-start-1">
                    <p class="eyebrow mb-2">Follow along</p>
                    <h3 class="font-display text-xl text-parchment sm:text-2xl">Follow Our Content</h3>
                    <p class="mt-3 text-sm leading-relaxed text-parchment-300">
                        Follow The Capable Muslim across your favorite platforms for articles, videos,
                        practical guides, and weekly insights.
                    </p>
                </header>

                <ul id="social-grid" class="order-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:col-start-2 lg:row-start-2 lg:self-start">
                        {
                            socialPlatforms.map((platform) => (
                                <li>
                                    <a
                                        href={platform.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="card group flex h-full min-h-[6.75rem] flex-col items-center justify-center p-3 text-center transition-colors hover:border-gold/30 sm:min-h-[7.75rem] sm:p-4"
                                        aria-label={`Visit ${platform.name}`}
                                    >
                                        <div
                                            class="mb-3 flex h-12 w-12 items-center justify-center rounded bg-gold/10 text-gold transition-all duration-200 group-hover:scale-105 group-hover:bg-gold/15 sm:h-14 sm:w-14"
                                            aria-hidden="true"
                                        >
                                            <PlatformIcon id={platform.id} class="h-6 w-6 sm:h-7 sm:w-7" />
                                        </div>
                                        <span class="font-display text-sm font-bold leading-tight text-parchment">
                                            {platform.name}
                                        </span>
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
            </div>
        </div>
    </section>

    <script>
        const syncCommunityListHeight = () => {
            const socialGrid = document.getElementById('social-grid');
            const communityList = document.getElementById('community-list');
            if (!socialGrid || !communityList) return;

            if (window.matchMedia('(min-width: 1024px)').matches) {
                communityList.style.height = `${socialGrid.offsetHeight}px`;
            } else {
                communityList.style.height = '';
            }
        };

        syncCommunityListHeight();
        window.addEventListener('resize', syncCommunityListHeight);
        document.fonts?.ready?.then(syncCommunityListHeight);
    </script>

    <!-- Bottom CTA -->
    <section class="section-padding" aria-labelledby="cta-heading">
        <div class="container-content">
            <div class="card mx-auto max-w-2xl p-6 text-center sm:p-8">
                <h2 id="cta-heading" class="font-display text-xl text-parchment sm:text-2xl">
                    Become Part of the Mission
                </h2>
                <p class="mx-auto mt-3 max-w-prose text-sm leading-relaxed text-parchment-300">
                    Every article, conversation, and shared experience helps build a stronger
                    community. We'd love to have you with us.
                </p>
                <div class="mx-auto mt-5 max-w-sm">
                    <form class="flex flex-col gap-2 sm:flex-row sm:items-end" action="#" method="post">
                        <div class="flex-1 text-left">
                            <label
                                for="community-newsletter-email"
                                class="text-[10px] font-semibold uppercase tracking-wider text-gold"
                            >
                                Email address
                            </label>
                            <input
                                type="email"
                                id="community-newsletter-email"
                                name="email"
                                required
                                placeholder="you@example.com"
                                class="input-field mt-1 py-2 text-sm"
                            />
                        </div>
                        <button type="submit" class="btn-primary w-full shrink-0 px-4 py-2 text-sm sm:w-auto">
                            Subscribe
                        </button>
                    </form>
                    <p class="mt-2 text-[11px] leading-relaxed text-parchment-400">
                        Free. Unsubscribe anytime.
                    </p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
